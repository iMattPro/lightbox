{
	"author": "Matt Friedman",
	"license": "GPL-2.0",
	"dependencies": {
		"lightbox3": "^1.1.0"
	},
	"devDependencies": {
		"copyfiles": "^2.4.1",
		"jest": "^29.7.0",
		"jest-environment-jsdom": "^29.0.0",
		"npm-run-all": "^4.1.5"
	},
	"jest": {
		"testEnvironment": "jsdom",
		"testMatch": [
			"**/tests/js/**/*.test.js"
		],
		"collectCoverageFrom": [
			"styles/all/template/js/**/*.js"
		],
		"setupFilesAfterEnv": [
			"<rootDir>/tests/js/setup.js"
		]
	},
	"scripts": {
		"build": "npm run copy-lightbox",
		"copy-lightbox": "run-s copy-lightbox:js copy-lightbox:css",
		"copy-lightbox:js": "copyfiles -u 3 node_modules/lightbox3/dist/lightbox3.min.js node_modules/lightbox3/dist/lightbox3.min.js.map styles/all/template/js",
		"copy-lightbox:css": "copyfiles -u 3 node_modules/lightbox3/dist/lightbox3.css styles/all/theme",
		"test": "jest",
		"test:basic": "jest resizer.test.js",
		"test:comprehensive": "jest resizer.comprehensive.test.js",
		"test:watch": "jest --watch",
		"test:coverage": "jest --coverage"
	}
}
